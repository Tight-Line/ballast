#!/bin/bash
# Pre-commit hook for ballast
# Install with: make setup-hooks

set -e

echo "Running pre-commit checks..."

if ! command -v golangci-lint &> /dev/null; then
    echo "Error: golangci-lint is not installed."
    echo "Run 'make tools' to install required development tools."
    exit 1
fi

STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)

if [ -z "$STAGED_GO_FILES" ]; then
    echo "No Go files staged, skipping lint check."
    exit 0
fi

echo "Checking formatting..."
# shellcheck disable=SC2086
UNFORMATTED=$(gofmt -l $STAGED_GO_FILES)
if [ -n "$UNFORMATTED" ]; then
    echo "Error: The following files are not formatted:"
    echo "$UNFORMATTED"
    echo ""
    echo "Run 'make fmt' to fix formatting issues."
    exit 1
fi

echo "Running linter..."
if ! golangci-lint run ./...; then
    echo ""
    echo "Linting failed. Fix the issues above or run 'make lint-fix' for auto-fixable issues."
    exit 1
fi

echo "Pre-commit checks passed."
