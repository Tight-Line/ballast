#!/bin/bash
#
# Creates a release tag with proper versioning.
#
# Usage: scripts/make-tag <version>
# Example: scripts/make-tag 0.1.1
#

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

info() {
    echo -e "${GREEN}-${NC} $1"
}

warn() {
    echo -e "${YELLOW}!${NC} $1"
}

error() {
    echo -e "${RED}ERROR:${NC} $1" >&2
    exit 1
}

if [ -z "$1" ]; then
    echo "Usage: scripts/make-tag <version>"
    echo "Example: scripts/make-tag 0.1.1"
    exit 1
fi

VERSION="$1"
TAG="v${VERSION}"

if ! [[ "$VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    error "Version must be in semver format (e.g., 0.1.1)"
fi

BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [ "$BRANCH" != "main" ]; then
    error "Must be on main branch (currently on '$BRANCH')"
fi

if ! git diff --quiet HEAD; then
    error "Working directory has uncommitted changes"
fi

if git rev-parse "$TAG" >/dev/null 2>&1; then
    error "Tag $TAG already exists"
fi

if ! grep -q "^## \[Unreleased\]" CHANGELOG.md; then
    error "CHANGELOG.md missing [Unreleased] section"
fi

UNRELEASED_CONTENT=$(sed -n '/^## \[Unreleased\]/,/^## \[/p' CHANGELOG.md | sed '1d;$d')
if [ -z "$(echo "$UNRELEASED_CONTENT" | grep -v '^$' | grep -v '^###')" ]; then
    error "No content in [Unreleased] section of CHANGELOG.md"
fi

echo "Creating release $TAG"
echo ""

info "Running checks..."
if ! make check >/dev/null 2>&1; then
    error "Checks failed. Fix issues before releasing."
fi
info "Checks passed"

info "Updating Helm chart versions to $VERSION..."
if [ -f "charts/ballast/Chart.yaml" ]; then
    sed -i.bak "s/^version: .*/version: $VERSION/" "charts/ballast/Chart.yaml"
    sed -i.bak "s/^appVersion: .*/appVersion: \"$TAG\"/" "charts/ballast/Chart.yaml"
    rm -f "charts/ballast/Chart.yaml.bak"
fi

info "Updating CHANGELOG.md..."
TODAY=$(date +%Y-%m-%d)

{
    sed -n '1,/^## \[Unreleased\]/p' CHANGELOG.md | sed '$d'
    echo "## [Unreleased]"
    echo ""
    echo "## [$VERSION] - $TODAY"
    sed -n '/^## \[Unreleased\]/,/^## \[/p' CHANGELOG.md | sed '1d;$d'
    sed -n '/^## \[Unreleased\]/,$p' CHANGELOG.md | sed -n '/^## \[[0-9]/,$p'
} > CHANGELOG.md.new

mv CHANGELOG.md.new CHANGELOG.md

info "Committing version changes..."
git add CHANGELOG.md charts/ballast/Chart.yaml 2>/dev/null || git add CHANGELOG.md
git commit -m "Release $TAG

- Update Helm chart version to $VERSION
- Move unreleased changes to $VERSION in CHANGELOG.md"

info "Creating tag $TAG..."
git tag -a "$TAG" -m "Release $VERSION"

echo ""
echo -e "${GREEN}Done!${NC} Now run:"
echo ""
echo "  git push origin main $TAG"
echo ""
